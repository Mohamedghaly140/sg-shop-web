{
  "name": "sg-shop-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "start": "bun run --bun next start",
    "lint": "eslint",
    "postinstall": "bun --bun run prisma generate",
    "prisma:push": "bun --bun run prisma db push",
    "prisma:generate": "bun --bun run prisma generate",
